# Dependencies
node_modules/

# Vendored backend deps — committed so the Databricks Apps runtime needs no npm
# registry access at startup (start.sh skips `npm ci` when backend/node_modules exists).
!backend/node_modules/
!backend/node_modules/**

# Environment variables
.env
.env.local
.env.*.local

# Build output
# frontend/dist/  # Needed for Databricks App deployment
frontend/build/

# OS files
.DS_Store
Thumbs.db

# Databricks bundle / IDE (local)
.databricks/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Temp files
tmp/
.tmp/

# Last published notebook SHA (local dev — workspace re-import when bundle changes)
backend/.notebook_publish_sig

# Extracted DBC contents (generated)
_dbc_extract/
